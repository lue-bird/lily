{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "lily",
      "camelcase": "Lily",
      "title": "lily",
      "scope": "source.lily",
      "file-types": ["lily"],
      "injection-regex": "^lily$",
      "class-name": "TreeSitterLily"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Unlicense",
    "description": "Lily grammar for tree-sitter",
    "authors": [
      {
        "name": "lue-bird"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-lily"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
